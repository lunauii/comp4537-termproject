---
// src/pages/lesson.astro
// Minimal, standalone lesson view (no Layout/Navbar)
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lesson | SISA</title>
    <style>
        :root {
            --bg: #111111;
            --surface: #1e1e1e;
            --surface-hover: #2a2a2a;
            --text: #ffffff;
            --text-muted: #a0a0a0;
            --accent: #39ff85;
            --error: #ff5e5e;
            --font-main: system-ui, -apple-system, sans-serif;
            --font-mono: ui-monospace, 'Cascadia Code', monospace;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: var(--font-main);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* --- Header & Progress --- */
        .lesson-header {
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .close-btn {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 1.5rem;
            font-weight: bold;
        }
        .progress-bar-bg {
            flex: 1;
            height: 16px;
            background: var(--surface);
            border-radius: 8px;
            overflow: hidden;
        }
        .progress-bar-fill {
            height: 100%;
            background: var(--accent);
            width: 0%;
            transition: width 0.3s ease;
            border-radius: 8px;
        }

        /* --- Main Content Area --- */
        .lesson-content {
            flex: 1;
            overflow-y: auto;
            padding: 2rem;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        h1 { font-size: 2rem; margin-bottom: 1rem; }
        p.explanation { font-size: 1.1rem; line-height: 1.6; color: var(--text-muted); }
        h2.prompt { font-size: 1.5rem; margin-bottom: 2rem; }

        /* --- Multiple Choice --- */
        .mc-grid {
            display: grid;
            gap: 1rem;
        }
        .mc-option {
            background: var(--surface);
            border: 2px solid transparent;
            padding: 1.5rem;
            border-radius: 12px;
            cursor: pointer;
            font-family: var(--font-mono);
            font-size: 1.1rem;
            transition: all 0.2s;
        }
        .mc-option:hover { background: var(--surface-hover); }
        .mc-option.selected {
            border-color: var(--accent);
            background: rgba(57, 255, 133, 0.1);
        }

        /* --- Tap to Build (Drag & Drop alternative) --- */
        .builder-area {
            min-height: 80px;
            border-bottom: 2px solid var(--surface);
            margin-bottom: 2rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            padding-bottom: 1rem;
        }
        .word-bank {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .word-chip {
            background: var(--surface);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-family: var(--font-mono);
            cursor: pointer;
            user-select: none;
            border: 1px solid #333;
        }
        .word-chip:hover { background: var(--surface-hover); }
        .word-chip.hidden { visibility: hidden; }

        /* --- AI Hint Box --- */
        .hint-box {
            background: rgba(57, 255, 133, 0.05);
            border: 1px dashed var(--accent);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 2rem;
            font-family: var(--font-mono);
            font-size: 0.9rem;
            display: none;
            white-space: pre-wrap;
        }

        /* --- Footer (Action Bar) --- */
        .lesson-footer {
            padding: 1.5rem 2rem;
            background: var(--bg);
            border-top: 2px solid var(--surface);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .lesson-footer.correct-state { background: rgba(57, 255, 133, 0.1); border-color: var(--accent); }
        .lesson-footer.wrong-state { background: rgba(255, 94, 94, 0.1); border-color: var(--error); }

        .btn {
            padding: 1rem 2rem;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: bold;
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: opacity 0.2s;
        }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn:active { transform: translateY(2px); }
        
        .btn-check { background: var(--surface); color: var(--text); }
        .btn-check.ready { background: var(--accent); color: #000; }
        .btn-hint { background: transparent; color: var(--accent); border: 2px solid var(--surface); }
        
        .footer-message {
            font-size: 1.2rem;
            font-weight: bold;
            display: none;
        }
        .correct-state .footer-message { display: block; color: var(--accent); }
        .wrong-state .footer-message { display: block; color: var(--error); }
    </style>
</head>
<body>

    <header class="lesson-header">
        <a href="/lessons" class="close-btn">×</a>
        <div class="progress-bar-bg">
            <div class="progress-bar-fill" id="progressBar"></div>
        </div>
    </header>

    <main class="lesson-content" id="contentArea">
        <h1 style="text-align: center; margin-top: 20vh;">Loading lesson...</h1>
    </main>

    <footer class="lesson-footer" id="footerArea" style="display: none;">
        <button class="btn btn-hint" id="hintBtn" style="display: none;">Get AI Hint</button>
        <div class="footer-message" id="footerMsg"></div>
        <button class="btn btn-check" id="mainBtn" disabled>Continue</button>
    </footer>

    <script>
        const API = 'https://sisa.lunaui.cc';
        const urlParams = new URLSearchParams(window.location.search);
        const lessonId = urlParams.get('id');

        let lessonData = null;
        let currentStep = -1; // -1: Intro, 0-4: Questions, 5: Done
        let selectedAnswer = null; // Stores string for MC, array for Drag/Drop
        let currentWordBank = [];

        const contentArea = document.getElementById('contentArea');
        const footerArea = document.getElementById('footerArea');
        const mainBtn = document.getElementById('mainBtn');
        const hintBtn = document.getElementById('hintBtn');
        const progressBar = document.getElementById('progressBar');
        const footerMsg = document.getElementById('footerMsg');

        // --- Fetch Lesson Data ---
        async function loadLesson() {
            const token = localStorage.getItem('token');
            if (!token || !lessonId) return window.location.href = '/login';

            try {
                const res = await fetch(`${API}/api/v1/lessons/${lessonId}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const json = await res.json();
                if (!res.ok) throw new Error(json.message);
                
                lessonData = json.data;
                renderStep();
            } catch (err) {
                contentArea.innerHTML = `<h1 style="color: var(--error)">Error loading lesson.</h1><p>${err.message}</p>`;
            }
        }

        // --- Render UI based on State ---
        function renderStep() {
            footerArea.style.display = 'flex';
            footerArea.className = 'lesson-footer';
            footerMsg.style.display = 'none';
            hintBtn.style.display = 'none';
            selectedAnswer = null;
            
            // Calculate Progress
            const totalSteps = lessonData.questions.length + 1;
            const progressPct = ((currentStep + 1) / totalSteps) * 100;
            progressBar.style.width = `${progressPct}%`;

            if (currentStep === -1) {
                // Intro Paragraph
                mainBtn.textContent = 'Start Lesson';
                mainBtn.disabled = false;
                mainBtn.className = 'btn btn-check ready';
                mainBtn.onclick = () => { currentStep++; renderStep(); };
                
                contentArea.innerHTML = `
                    <h1>${lessonData.title}</h1>
                    <p class="explanation">${lessonData.explanation}</p>
                `;
            } else if (currentStep < lessonData.questions.length) {
                // Question
                const q = lessonData.questions[currentStep];
                mainBtn.textContent = 'Check';
                mainBtn.disabled = true;
                mainBtn.className = 'btn btn-check';
                hintBtn.style.display = 'block';
                
                mainBtn.onclick = checkAnswer;
                hintBtn.onclick = requestHint;

                let html = `
                    <h2 class="prompt">${q.prompt}</h2>
                    <div id="aiHintBox" class="hint-box"></div>
                `;

                if (q.type === 'multiple_choice') {
                    html += `<div class="mc-grid">`;
                    q.content.options.forEach((opt, idx) => {
                        html += `<div class="mc-option" data-idx="${idx}">${opt.replace(/</g, "&lt;")}</div>`;
                    });
                    html += `</div>`;
                    contentArea.innerHTML = html;

                    document.querySelectorAll('.mc-option').forEach(el => {
                        el.addEventListener('click', (e) => {
                            document.querySelectorAll('.mc-option').forEach(c => c.classList.remove('selected'));
                            e.target.classList.add('selected');
                            selectedAnswer = q.content.options[e.target.dataset.idx];
                            mainBtn.disabled = false;
                            mainBtn.className = 'btn btn-check ready';
                        });
                    });
                } else if (q.type === 'drag_and_drop') {
                    selectedAnswer = [];
                    // Shuffle word bank
                    currentWordBank = [...q.content.blocks].sort(() => Math.random() - 0.5);
                    
                    html += `
                        <div class="builder-area" id="builderArea"></div>
                        <div class="word-bank" id="wordBank"></div>
                    `;
                    contentArea.innerHTML = html;
                    renderWordBank();
                }
            } else {
                // Done
                mainBtn.textContent = 'Finish';
                mainBtn.className = 'btn btn-check ready';
                mainBtn.disabled = false;
                mainBtn.onclick = () => window.location.href = '/lessons';
                contentArea.innerHTML = `
                    <h1 style="color: var(--accent); text-align: center;">Lesson Complete!</h1>
                    <p style="text-align: center; color: var(--text-muted);">Great job finishing ${lessonData.title}.</p>
                `;
            }
        }

        // --- Drag and Drop (Tap to Build) Logic ---
        function renderWordBank() {
            const builderArea = document.getElementById('builderArea');
            const wordBank = document.getElementById('wordBank');
            builderArea.innerHTML = '';
            wordBank.innerHTML = '';

            selectedAnswer.forEach((word, index) => {
                const chip = document.createElement('div');
                chip.className = 'word-chip';
                chip.textContent = word;
                chip.onclick = () => {
                    selectedAnswer.splice(index, 1);
                    renderWordBank();
                    checkBuilderState();
                };
                builderArea.appendChild(chip);
            });

            currentWordBank.forEach((word, index) => {
                const chip = document.createElement('div');
                chip.className = 'word-chip';
                chip.textContent = word;
                
                // If it's already in the builder, hide it from the bank
                const countInBuilder = selectedAnswer.filter(w => w === word).length;
                const countInBankSoFar = currentWordBank.slice(0, index + 1).filter(w => w === word).length;
                if (countInBankSoFar <= countInBuilder) {
                    chip.classList.add('hidden');
                } else {
                    chip.onclick = () => {
                        selectedAnswer.push(word);
                        renderWordBank();
                        checkBuilderState();
                    };
                }
                wordBank.appendChild(chip);
            });
        }

        function checkBuilderState() {
            if (selectedAnswer.length > 0) {
                mainBtn.disabled = false;
                mainBtn.className = 'btn btn-check ready';
            } else {
                mainBtn.disabled = true;
                mainBtn.className = 'btn btn-check';
            }
        }

        // --- Checking Logic ---
        function checkAnswer() {
            const q = lessonData.questions[currentStep];
            let isCorrect = false;

            if (q.type === 'multiple_choice') {
                isCorrect = selectedAnswer === q.content.correctAnswer;
            } else {
                // Compare arrays for drag and drop
                isCorrect = JSON.stringify(selectedAnswer) === JSON.stringify(q.content.correctSequence);
            }

            hintBtn.style.display = 'none';

            if (isCorrect) {
                footerArea.className = 'lesson-footer correct-state';
                footerMsg.textContent = "Excellent!";
                mainBtn.textContent = "Continue";
                mainBtn.onclick = () => { currentStep++; renderStep(); };
            } else {
                footerArea.className = 'lesson-footer wrong-state';
                footerMsg.textContent = "Not quite. Try again.";
                mainBtn.textContent = "Got it";
                // Reset the checking state
                mainBtn.onclick = () => {
                    footerArea.className = 'lesson-footer';
                    footerMsg.style.display = 'none';
                    mainBtn.textContent = "Check";
                    hintBtn.style.display = 'block';
                    mainBtn.onclick = checkAnswer;
                };
            }
        }

        // --- AI Hint Streaming ---
        async function requestHint() {
            const token = localStorage.getItem('token');
            const q = lessonData.questions[currentStep];
            const hintBox = document.getElementById('aiHintBox');
            
            hintBox.style.display = 'block';
            hintBox.textContent = 'Thinking...';
            hintBtn.disabled = true;

            // Gather the student's current code attempt
            let currentCode = q.type === 'multiple_choice' 
                ? (selectedAnswer || "Nothing selected yet")
                : selectedAnswer.join(" ");

            try {
                const response = await fetch(`${API}/api/v1/getHintStream`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        problemStatement: q.hint_prompt,
                        code: currentCode
                    })
                });

                if (response.status === 429) {
                    hintBox.textContent = "API call limit reached for today.";
                    return;
                }

                hintBox.textContent = '';
                const reader = response.body.getReader();
                const decoder = new TextDecoder("utf-8");

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    const chunk = decoder.decode(value, { stream: true });
                    const lines = chunk.split('\n');
                    
                    for (const line of lines) {
                        if (line.startsWith('data: ') && line !== 'data: [DONE]') {
                            try {
                                const data = JSON.parse(line.replace('data: ', ''));
                                if (data.text) hintBox.textContent += data.text;
                                if (data.error) hintBox.textContent = "Error: " + data.error;
                            } catch (e) { }
                        }
                    }
                }
            } catch (err) {
                hintBox.textContent = "Failed to load hint.";
            } finally {
                hintBtn.disabled = false;
            }
        }

        // Initialize
        loadLesson();
    </script>
</body>
</html>