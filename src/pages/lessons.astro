---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Learning Path">
    <div class="path-wrapper">
        <header class="path-header">
            <h1>C Fundamentals</h1>
            <p>Master the basics of C programming</p>
        </header>

        <main class="path-container" id="lessonsContainer">
            <div class="loading-state">Loading your path...</div>
        </main>
    </div>
</Layout>

<style>
    .path-wrapper {
        max-width: 600px;
        margin: 0 auto;
        padding: 2rem;
        min-height: calc(100vh - 60px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .path-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .path-header h1 {
        font-size: 2rem;
        color: var(--text);
        margin-bottom: 0.5rem;
    }

    .path-header p {
        color: #7070a0;
        font-family: var(--font-mono);
        font-size: 0.9rem;
    }

    .path-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        position: relative;
    }

    /* Creates the connecting vertical line behind the nodes */
    .path-container::before {
        content: '';
        position: absolute;
        top: 20px;
        bottom: 20px;
        left: 50%;
        width: 4px;
        background: var(--bg-3);
        transform: translateX(-50%);
        z-index: 0;
        border-radius: 2px;
    }

    .loading-state {
        color: var(--accent);
        font-family: var(--font-mono);
        background: var(--bg-2);
        padding: 1rem 2rem;
        border-radius: 20px;
        z-index: 1;
    }

    /* Styles injected via JavaScript */
    :global(.lesson-node) {
        position: relative;
        z-index: 1;
        background: var(--bg-2);
        border: 3px solid var(--border);
        border-radius: 50%;
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: var(--text);
        font-weight: bold;
        font-size: 1.5rem;
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 4px 0 var(--border);
    }

    :global(.lesson-node:hover) {
        transform: translateY(-2px) scale(1.05);
        border-color: var(--accent);
        box-shadow: 0 6px 0 var(--accent);
        color: var(--accent);
    }

    :global(.lesson-node:active) {
        transform: translateY(4px) scale(0.95);
        box-shadow: 0 0 0 var(--accent);
    }

    :global(.lesson-title-tooltip) {
        position: absolute;
        top: -40px;
        background: var(--surface);
        color: var(--text);
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-family: var(--font-mono);
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s;
        transform: translateY(10px);
        border: 1px solid var(--border);
    }

    :global(.lesson-node:hover .lesson-title-tooltip) {
        opacity: 1;
        transform: translateY(0);
    }

    /* Zig-zag offset for the Duolingo look */
    :global(.lesson-node:nth-child(even)) { margin-left: 120px; }
    :global(.lesson-node:nth-child(odd)) { margin-right: 120px; }
</style>

<script>
    const API = 'http://localhost:3030';

    async function loadLessons() {
        const token = localStorage.getItem('token');
        const container = document.getElementById('lessonsContainer');

        if (!token) {
            window.location.href = '/login';
            return;
        }

        try {
            const res = await fetch(`${API}/api/v1/lessons`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });

            if (res.status === 401 || res.status === 403) {
                localStorage.removeItem('token');
                window.location.href = '/login';
                return;
            }

            const json = await res.json();
            
            if (!res.ok) throw new Error(json.message);

            const lessons = json.data;
            container.innerHTML = ''; // Clear loading state

            if (lessons.length === 0) {
                container.innerHTML = '<div class="loading-state">No lessons found. Ask an admin to seed the database!</div>';
                return;
            }

            // Generate a node for each lesson
            lessons.forEach((lesson, index) => {
                const node = document.createElement('a');
                // This is the crucial part: linking via the URL query parameter
                node.href = `/lesson?id=${lesson.id}`;
                node.className = 'lesson-node';
                
                // Display a number inside the circle, and a tooltip with the title on hover
                node.innerHTML = `
                    ${index + 1}
                    <div class="lesson-title-tooltip">${lesson.title}</div>
                `;

                container.appendChild(node);
            });

        } catch (err) {
            console.error(err);
            container.innerHTML = `<div class="loading-state" style="color: red;">Failed to load path. Server offline?</div>`;
        }
    }

    loadLessons();
</script>