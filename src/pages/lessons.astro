---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lessons">
    <div class="lessons-wrapper">
        <div class="lessons-inner">

            <div class="lessons-header">
                <p class="lessons-eyebrow">// learning path</p>
                <h1 class="lessons-title">C Programming</h1>
                <p class="lessons-sub">Complete lessons in order to unlock the next.</p>
            </div>

            <div class="path-container">

                <!-- Node 1 — unlocked, left -->
                <div class="path-row left">
                    <div class="node-slot">
                        <button class="hex-node unlocked" data-lesson="1" onclick="openLesson(1)">
                            <svg class="hex-bg" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg">
                                <polygon points="50,2 98,27 98,88 50,113 2,88 2,27" />
                            </svg>
                            <span class="node-number">1</span>
                            <span class="node-title">Variables &amp; Types</span>
                        </button>
                    </div>
                </div>

                <!-- Connector 1→2: sweeps right -->
                <div class="connector-row">
                    <svg class="connector-svg" viewBox="0 0 300 90" xmlns="http://www.w3.org/2000/svg">
                        <path class="connector-path" d="M 70,10 Q 150,10 150,45 Q 150,80 230,80" />
                    </svg>
                </div>

                <!-- Node 2 — locked, right -->
                <div class="path-row right">
                    <div class="node-slot">
                        <button class="hex-node locked" data-lesson="2" disabled>
                            <svg class="hex-bg" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg">
                                <polygon points="50,2 98,27 98,88 50,113 2,88 2,27" />
                            </svg>
                            <span class="lock-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </span>
                            <span class="node-number">2</span>
                            <span class="node-title">Control Flow</span>
                        </button>
                    </div>
                </div>

                <!-- Connector 2→3: sweeps left -->
                <div class="connector-row">
                    <svg class="connector-svg" viewBox="0 0 300 90" xmlns="http://www.w3.org/2000/svg">
                        <path class="connector-path" d="M 230,10 Q 150,10 150,45 Q 150,80 70,80" />
                    </svg>
                </div>

                <!-- Node 3 — locked, left -->
                <div class="path-row left">
                    <div class="node-slot">
                        <button class="hex-node locked" data-lesson="3" disabled>
                            <svg class="hex-bg" viewBox="0 0 100 115" xmlns="http://www.w3.org/2000/svg">
                                <polygon points="50,2 98,27 98,88 50,113 2,88 2,27" />
                            </svg>
                            <span class="lock-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </span>
                            <span class="node-number">3</span>
                            <span class="node-title">Functions &amp; Pointers</span>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Lesson popup -->
    <div class="lesson-popup" id="lessonPopup">
        <button class="popup-close" onclick="closePopup()">✕</button>
        <p class="popup-eyebrow">lesson 1</p>
        <p class="popup-title">Variables &amp; Types</p>
        <p class="popup-desc">Learn about int, char, float, and how C handles memory at a low level.</p>
        <a href="/hint" class="btn btn-primary popup-btn">Start lesson →</a>
    </div>
    <div class="popup-backdrop" id="popupBackdrop" onclick="closePopup()"></div>
</Layout>

<style>
    .lessons-wrapper {
        flex: 1;
        display: flex;
        justify-content: center;
        padding: 3rem 2rem 6rem;
        min-height: calc(100vh - 60px);
    }

    .lessons-inner {
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    /* ── Header ── */
    .lessons-header {
        text-align: center;
        animation: fadeUp 0.35s ease both;
    }

    .lessons-eyebrow {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--accent);
        letter-spacing: 0.08em;
        margin-bottom: 0.45rem;
    }

    .lessons-title {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 0.4rem;
    }

    .lessons-sub {
        font-size: 0.83rem;
        color: #7070a0;
        font-family: var(--font-mono);
    }

    /* ── Path ── */
    .path-container {
        display: flex;
        flex-direction: column;
    }

    .path-row {
        display: flex;
        animation: fadeUp 0.35s ease both;
    }

    .path-row.left  { justify-content: flex-start; animation-delay: 0.08s; }
    .path-row.right { justify-content: flex-end;   animation-delay: 0.18s; }
    .path-row:last-child { animation-delay: 0.28s; }

    .node-slot {
        width: 140px;
        display: flex;
        justify-content: center;
    }

    /* ── Hex node ── */
    .hex-node {
        position: relative;
        width: 120px;
        height: 138px;
        background: none;
        border: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.17s ease, filter 0.17s ease;
    }

    .hex-node.unlocked:hover {
        transform: translateY(-5px) scale(1.05);
        filter: drop-shadow(0 10px 28px rgba(57, 255, 133, 0.4));
    }

    .hex-node.unlocked:active {
        transform: translateY(-2px) scale(1.02);
    }

    .hex-node.locked {
        cursor: not-allowed;
    }

    /* hex SVG background */
    .hex-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .unlocked .hex-bg polygon {
        fill: var(--accent);
        stroke: #7fffbb;
        stroke-width: 1.5;
    }

    .locked .hex-bg polygon {
        fill: var(--bg-3);
        stroke: var(--border);
        stroke-width: 1.5;
    }

    /* node content */
    .node-number {
        position: relative;
        z-index: 1;
        font-family: var(--font-mono);
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1;
    }

    .unlocked .node-number { color: #0a0a0c; }
    .locked   .node-number { color: #505065; margin-top: 18px; }

    .node-title {
        position: relative;
        z-index: 1;
        font-family: var(--font-mono);
        font-size: 0.56rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-align: center;
        max-width: 74px;
        line-height: 1.35;
        margin-top: 3px;
    }

    .unlocked .node-title { color: rgba(10, 10, 12, 0.65); }
    .locked   .node-title { color: #404055; }

    /* lock icon */
    .lock-icon {
        position: absolute;
        top: 28px;
        z-index: 1;
        width: 20px;
        height: 20px;
        color: #505065;
    }

    .lock-icon svg { width: 100%; height: 100%; }

    /* ── Connectors ── */
    .connector-row {
        height: 90px;
        width: 100%;
        animation: fadeUp 0.35s ease both;
        animation-delay: 0.13s;
    }

    .connector-svg {
        width: 100%;
        height: 100%;
    }

    .connector-path {
        fill: none;
        stroke: var(--border);
        stroke-width: 3;
        stroke-dasharray: 7 5;
        stroke-linecap: round;
    }

    /* ── Popup ── */
    .popup-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 200;
    }

    .popup-backdrop.open { display: block; }

    .lesson-popup {
        display: none;
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%) translateY(16px);
        z-index: 201;
        width: min(380px, calc(100vw - 2rem));
        background: var(--bg-2);
        border: 1px solid var(--accent-dim);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 24px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(57,255,133,0.07);
        opacity: 0;
        transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .lesson-popup.open {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    .popup-close {
        position: absolute;
        top: 0.9rem;
        right: 1rem;
        background: none;
        border: none;
        color: #7070a0;
        font-size: 0.85rem;
        cursor: pointer;
        transition: color 0.15s;
    }

    .popup-close:hover { color: var(--text); }

    .popup-eyebrow {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.3rem;
    }

    .popup-title {
        font-size: 1.3rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
    }

    .popup-desc {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: #7070a0;
        line-height: 1.65;
        margin-bottom: 1.2rem;
    }

    .popup-btn {
        width: 100%;
        padding: 0.8rem;
        text-align: center;
        display: block;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    const token = localStorage.getItem('token');
    if (!token) window.location.href = '/login';

    function openLesson(num) {
        const popup    = document.getElementById('lessonPopup');
        const backdrop = document.getElementById('popupBackdrop');
        popup.style.display = 'block';
        requestAnimationFrame(() => requestAnimationFrame(() => {
            popup.classList.add('open');
            backdrop.classList.add('open');
        }));
    }

    function closePopup() {
        const popup    = document.getElementById('lessonPopup');
        const backdrop = document.getElementById('popupBackdrop');
        popup.classList.remove('open');
        backdrop.classList.remove('open');
        setTimeout(() => { popup.style.display = 'none'; }, 210);
    }

    window.openLesson = openLesson;
    window.closePopup = closePopup;
</script>