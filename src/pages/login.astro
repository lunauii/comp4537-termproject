---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login">
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <p class="auth-eyebrow">// welcome back</p>
                <h1 class="auth-title">Sign in</h1>
                <p class="auth-sub">Don't have an account? <a href="/register">Register</a></p>
            </div>

            <form id="loginForm" class="auth-form">
                <div class="form-group">
                    <label class="form-label" for="email">email</label>
                    <input
                        class="form-input"
                        type="email"
                        id="email"
                        name="email"
                        placeholder="you@example.com"
                        required
                        autocomplete="email"
                    />
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">password</label>
                    <input
                        class="form-input"
                        type="password"
                        id="password"
                        name="password"
                        placeholder="••••••••"
                        required
                        autocomplete="current-password"
                    />
                </div>

                <div id="alert" class="alert" style="display:none;"></div>

                <button type="submit" class="btn btn-primary" id="submitBtn">
                    sign in
                </button>
            </form>
        </div>

        <!-- Decorative background grid -->
        <div class="bg-grid" aria-hidden="true"></div>
    </div>
</Layout>

<style>
    .auth-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        min-height: calc(100vh - 60px);
    }

    .bg-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(57, 255, 133, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(57, 255, 133, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    }

    .auth-card {
        width: 100%;
        max-width: 400px;
        position: relative;
        z-index: 1;
        animation: fadeUp 0.4s ease both;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .auth-header {
        margin-bottom: 2rem;
    }

    .auth-eyebrow {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--accent);
        margin-bottom: 0.5rem;
        letter-spacing: 0.05em;
    }

    .auth-title {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text);
        line-height: 1;
        margin-bottom: 0.75rem;
    }

    .auth-sub {
        font-size: 0.85rem;
        color: #7070a0;
    }

    .auth-sub a {
        color: var(--accent);
        transition: opacity 0.15s;
    }

    .auth-sub a:hover {
        opacity: 0.7;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .btn-primary {
        width: 100%;
        margin-top: 0.4rem;
        padding: 0.85rem;
        font-size: 0.9rem;
    }
</style>

<script>
    const API = 'https://sisa.lunaui.cc';

    // Redirect if already logged in
    if (localStorage.getItem('token')) {
        window.location.href = '/dashboard';
    }

    const form = document.getElementById('loginForm');
    const alertEl = document.getElementById('alert');
    const submitBtn = document.getElementById('submitBtn');

    function showAlert(message, type = 'error') {
        alertEl.textContent = message;
        alertEl.className = `alert alert-${type}`;
        alertEl.style.display = 'block';
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        alertEl.style.display = 'none';
        submitBtn.disabled = true;
        submitBtn.textContent = 'signing in...';

        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;

        try {
            const res = await fetch(`${API}/api/v1/user/login`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password }),
            });

            const data = await res.json();

            if (!res.ok) {
                showAlert(data.message || 'Login failed');
                return;
            }

            localStorage.setItem('token', data.token);
            localStorage.setItem('role', data.role);

            window.location.href = data.role === 'admin' ? '/admin' : '/dashboard';
        } catch (err) {
            showAlert('Could not reach the server. Try again.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'sign in';
        }
    });
</script>